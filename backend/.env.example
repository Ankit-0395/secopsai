# ── SecureOpsAI Environment Variables ──────────────────────
# Copy this file to .env and fill in your values

# OpenAI API Key (required for AI vulnerability analysis)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# MongoDB URI (optional – default uses in-memory storage)
# MONGODB_URI=mongodb://localhost:27017/secureopsai
